{
    "name": "idk/idk",
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "psr/container": "^2.0",
        "doctrine/dbal": "^4.4",
        "doctrine/orm": "^3.6",
        "symfony/cache": "^8.1",
        "symfony/var-exporter": "^8.1",
        "doctrine/migrations": "^3.9",
        "illuminate/database": "^13.18",
        "illuminate/events": "^13.18",
        "guzzlehttp/guzzle": "^7.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
